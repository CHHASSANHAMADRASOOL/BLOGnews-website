generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Posts {
  id          String   @id @default(cuid())
  title       String
  description String
  content     String
  bgImage     String
  category    String
  createdAt   DateTime @default(now())
}
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // Agar social login ke ilawa password rakhna ho
  isVerified    Boolean   @default(false)
  otp           String?
  otpExpires    DateTime?
}